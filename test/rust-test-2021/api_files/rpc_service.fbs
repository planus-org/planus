table HelloRequest {
  name: string;
}

table HelloReply {
  message: string (required);
}

/// A simple greeting service.
rpc_service Greeter {
  SayHello(HelloRequest): HelloReply;
  /// Says hello, but is also idempotent.
  SayHelloAgain(HelloRequest): HelloReply (idempotent, streaming: "none");
}
